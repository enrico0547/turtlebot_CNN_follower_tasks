          <waypoint>  
            <time>68.0</time>  
            <pose>-4 1 0 0 0 5.4953982</pose>  
          </waypoint>

          <waypoint>  
            <time>72.0</time>  
            <pose>-4 0.5 0 0 0 5.4953982</pose>  
          </waypoint> 

          <waypoint>  
            <time>72.0</time>  
